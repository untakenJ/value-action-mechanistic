# Copy this file to .env and fill in your HuggingFace token.
# Get a token at: https://huggingface.co/settings/tokens
# Accept the model license at: https://huggingface.co/google/gemma-3-4b-it

HF_TOKEN=hf_your_token_here

# Avoid 401 errors when downloading gated model weights via XET storage.
HF_HUB_DISABLE_XET=1
