# Copy this file to .env and fill in the credentials used by your run.

# Hugging Face access for the local subject model.
# Token: https://huggingface.co/settings/tokens
# Gemma license: https://huggingface.co/google/gemma-3-4b-it
HF_TOKEN=hf_your_token_here
HF_HUB_DISABLE_XET=1

# Required for the default LLM Judge.
# DeepSeek API docs: https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=sk_your_deepseek_key_here

# Optional generic OpenAI-compatible Judge overrides.
# JUDGE_API_KEY takes precedence over DEEPSEEK_API_KEY when non-empty.
JUDGE_API_KEY=
JUDGE_BASE_URL=https://api.deepseek.com
JUDGE_MODEL=deepseek-v4-pro
JUDGE_TEMPERATURE=0
JUDGE_MAX_TOKENS=512
JUDGE_TIMEOUT_SECONDS=60
JUDGE_MAX_ATTEMPTS=3
JUDGE_WORKERS=4

# DeepSeek supports enabled/disabled. Use omit for endpoints that do not
# accept the provider-specific thinking field.
JUDGE_THINKING=disabled
JUDGE_REASONING_EFFORT=high
